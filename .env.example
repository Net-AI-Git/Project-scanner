# Copy to .env and fill in. Do not commit .env.
# All config is loaded via Settings (summary_api.core.config). Kubernetes: set env vars from ConfigMaps/Secrets.

# Optional: GitHub token for API rate limit (5000/h). Required for real integration tests.
# Create at: https://github.com/settings/tokens (no scope needed for public repos)
GITHUB_TOKEN=

# LLM: Nebius Token Factory. Get key at https://tokenfactory.nebius.com/ → project/api-keys
NEBIUS_API_KEY=
# Optional: max tokens for LLM response (default 4096). Increase if summary/structure is cut off.
# NEBIUS_MAX_TOKENS=4096

# Optional: paths and logging (defaults: AUDIT.jsonl and DLQ.jsonl under project root)
# AUDIT_LOG_PATH=
# DLQ_PATH=
# LOG_FORMAT=json
# Optional: GitHub API base (default https://api.github.com)
# GITHUB_API_BASE=https://api.github.com

# Optional: LangSmith observability (traces and metrics for LangGraph/LLM). Get API key at https://smith.langchain.com/ (or https://eu.smith.langchain.com for EU)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=summary-api
# Required for EU region: uncomment and set to EU API endpoint
# LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
